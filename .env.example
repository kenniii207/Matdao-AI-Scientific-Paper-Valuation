# === MatDAO Automation Framework (Example) ===

# API Keys
OPENALEX_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
SERPAPI_API_KEY=
ZAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GLM_MODEL=glm-4.7-flash
GLM_VISION_MODEL=glm-4.6v-flash
GLM_OCR_MODEL=glm-ocr
GLM_OCR_LAYOUT_ENDPOINT=https://open.bigmodel.cn/api/paas/v4/layout_parsing
LLM_FALLBACK_ORDER=gemini,glm,openrouter,qwen,manus,kimi,minimax,liquid
LLM_PROVIDER_TIMEOUT_SECONDS=120
LLM_ADAPTIVE_ROUTING_ENABLED=true

# Optional OpenRouter fallback pool (recommended)
OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODELS=z-ai/glm-4.5-air:free,minimax/minimax-m2.5:free,google/gemma-4-31b-it:free,openai/gpt-oss-120b:free,nousresearch/hermes-3-llama-3.1-405b:free,nvidia/nemotron-3-nano-30b-a3b:free
OPENROUTER_MAX_MODELS_PER_EVAL=3
OPENROUTER_REASONING_ENABLED=true
# Optional metadata headers for OpenRouter
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=MatDAO

# Optional additional fallbacks
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2-latest
MINIMAX_API_KEY=
MINIMAX_BASE_URL=
MINIMAX_MODEL=
LIQUID_AI_API_KEY=
LIQUID_AI_BASE_URL=
LIQUID_AI_MODEL=
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
MANUS_API_KEY=
MANUS_BASE_URL=
MANUS_MODEL=

# OCR fallback configuration
OCR_FALLBACK_ORDER=pdf_text,glm_ocr,lighton_ocr
OCR_MAX_UPLOAD_BYTES=25000000
OCR_MAX_PAGES_SYNC_TEXT=30
OCR_RENDER_MAX_PIXELS=4000000
OCR_SAMPLE_PAGES=3
OCR_MAX_PARALLEL_CHAINS=2
OCR_FALLBACK_TIMEOUT_SECONDS=75
GLM_OCR_TIMEOUT_SECONDS=30
LIGHTONOCR_ENABLED=false
LIGHTONOCR_BASE_URL=
LIGHTONOCR_TIMEOUT_SECONDS=45
LIGHTONOCR_HEALTH_TIMEOUT_SECONDS=3
LIGHTONOCR_READINESS_CACHE_SECONDS=15
LIGHTONOCR_INCLUDE_TEXT_PROMPT=false
LIGHTONOCR_MODEL_PATH=
LIGHTONOCR_MMPROJ_PATH=
LIGHTONOCR_REQUIRE_LOCAL_PATHS=false
LIGHTONOCR_CANARY_PERCENT=0

# Optional source API URL overrides
# OPENALEX_BASE_URL=https://api.openalex.org
# SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1
# SERPAPI_BASE_URL=https://serpapi.com
# OSF_BASE_URL=https://api.osf.io/v2
# CLINICAL_TRIALS_BASE_URL=https://clinicaltrials.gov/api/v2

# Evaluation/Enrichment tuning (for lower cost/latency on Render)
EVALUATION_TEXT_MAX_CHARS=12000
THEME_SEARCH_RESULTS_PER_SOURCE=5
MAX_PARALLEL_EVALUATIONS=2
ENABLE_LOCAL_PREFILTER=false
ENABLE_LOCAL_RERANKER=false
LOCAL_PREFILTER_TOP_K=10
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
LOCAL_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2
LOCAL_MODEL_DEVICE=cpu
# LOCAL_MODEL_CACHE_DIR=/var/cache/huggingface
LOCAL_MODEL_LOAD_TIMEOUT_SECONDS=8
ENABLE_EXTERNAL_API_CACHE=true
EXTERNAL_API_CACHE_TTL_SECONDS=86400
EXTERNAL_API_CACHE_MAX_ENTRIES=500
ENABLE_CURATED_CACHE=true
CURATED_CACHE_TTL_SECONDS=86400
CURATED_CACHE_MAX_ENTRIES=500
EVALUATION_PIPELINE_TIMEOUT_SECONDS=120
EVALUATION_JOB_POLL_INTERVAL_SECONDS=1.5
EVALUATION_JOB_LEASE_SECONDS=240
EVALUATION_JOB_MAX_RETRIES=4
EVALUATION_JOB_RETRY_BASE_SECONDS=8
EVALUATION_STALE_SWEEP_INTERVAL_SECONDS=30

# Database
# For Local: postgresql+asyncpg://user:password@localhost:5432/db
# For Render: provided by blueprint
DATABASE_URL=

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=3000
