# === MatDAO Automation Framework (Example) ===

# API Keys
OPENALEX_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
SERPAPI_API_KEY=
ZAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
LLM_FALLBACK_ORDER=gemini,glm,openrouter,qwen,kimi,minimax,liquid
LLM_PROVIDER_TIMEOUT_SECONDS=120
LLM_ADAPTIVE_ROUTING_ENABLED=true

# Optional OpenRouter fallback pool (recommended)
OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODELS=nousresearch/hermes-3-llama-3.1-405b:free,openai/gpt-oss-120b:free,google/gemma-4-31b-it:free,nvidia/nemotron-3-nano-30b-a3b:free
OPENROUTER_REASONING_ENABLED=true
# Optional metadata headers for OpenRouter
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=MatDAO

# Optional additional fallbacks
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2-latest
MINIMAX_API_KEY=
MINIMAX_BASE_URL=
MINIMAX_MODEL=
LIQUID_AI_API_KEY=
LIQUID_AI_BASE_URL=
LIQUID_AI_MODEL=
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Evaluation/Enrichment tuning (for lower cost/latency on Render)
EVALUATION_TEXT_MAX_CHARS=12000
THEME_SEARCH_RESULTS_PER_SOURCE=5
MAX_PARALLEL_EVALUATIONS=2
ENABLE_LOCAL_PREFILTER=false
ENABLE_LOCAL_RERANKER=false
LOCAL_PREFILTER_TOP_K=10
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
LOCAL_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2
LOCAL_MODEL_DEVICE=cpu
# LOCAL_MODEL_CACHE_DIR=/var/cache/huggingface
LOCAL_MODEL_LOAD_TIMEOUT_SECONDS=8
ENABLE_EXTERNAL_API_CACHE=true
EXTERNAL_API_CACHE_TTL_SECONDS=86400
EXTERNAL_API_CACHE_MAX_ENTRIES=500
ENABLE_CURATED_CACHE=true
CURATED_CACHE_TTL_SECONDS=86400
CURATED_CACHE_MAX_ENTRIES=500
EVALUATION_PIPELINE_TIMEOUT_SECONDS=120

# Database
# For Local: postgresql+asyncpg://user:password@localhost:5432/db
# For Render: provided by blueprint
DATABASE_URL=

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=3000
