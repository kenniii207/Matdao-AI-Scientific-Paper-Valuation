# === MatDAO Automation Framework (Example) ===

# API Keys
OPENALEX_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
SERPAPI_API_KEY=
ZAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Evaluation/Enrichment tuning (for lower cost/latency on Render)
EVALUATION_TEXT_MAX_CHARS=12000
THEME_SEARCH_RESULTS_PER_SOURCE=5
MAX_PARALLEL_EVALUATIONS=2
ENABLE_LOCAL_PREFILTER=false
ENABLE_LOCAL_RERANKER=false
LOCAL_PREFILTER_TOP_K=10
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
LOCAL_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2
LOCAL_MODEL_DEVICE=cpu
# LOCAL_MODEL_CACHE_DIR=/var/cache/huggingface

# Database
# For Local: postgresql+asyncpg://user:password@localhost:5432/db
# For Render: provided by blueprint
DATABASE_URL=

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=3000
