# === MatDAO Automation Framework (Phase 2) ===

# API Keys
OPENALEX_API_KEY=your_openalex_api_key_here
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_here
SERPAPI_API_KEY=your_serpapi_api_key_here
ZHIPU_API_KEY=your_zhipu_api_key_here
ZAI_API_KEY=your_zai_api_key_here  # Fallback for GLM-OCR

# PostgreSQL (Render Managed or local)
# DATABASE_URL = link to matdao-postgres in Render
DATABASE_URL=postgresql+asyncpg://matdao:matdao_secret@localhost:5432/matdao
POSTGRES_URL=postgres://your_vercel_postgres_url  # For Vercel compatibility

# Grobid (CRF-only, lightweight ~478 MB image)
# Local dev (docker-compose): http://grobid:8070
# Render production:          Internal hostname from Blueprint (matdao-grobid)
GROBID_URL=http://localhost:8070

# App Settings
BACKEND_PORT=8000
FRONTEND_PORT=3000
