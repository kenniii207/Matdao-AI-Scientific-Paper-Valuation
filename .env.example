# === MatDAO Automation Framework ===

# OpenAlex API (required after Feb 2026)
OPENALEX_API_KEY=your_openalex_api_key_here

# Semantic Scholar API (100 req/sec with key)
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_here

# NIH RePORTER (polite pool - email for priority)
NIH_REPORTER_EMAIL=your_email@example.com

# Crossref (polite pool - email header)
CROSSREF_EMAIL=your_email@example.com

# GLM-OCR (Zhipu MaaS API key)
ZHIPU_API_KEY=your_zhipu_api_key_here

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://matdao:matdao_secret@localhost:5432/matdao_db

# Grobid (CRF-only, lightweight ~478 MB image)
# Local dev (docker-compose): http://grobid:8070
# Render production:          http://matdao-grobid:8070  (set in Render env panel)
GROBID_URL=http://localhost:8070

# App
BACKEND_PORT=8000
FRONTEND_PORT=3000
